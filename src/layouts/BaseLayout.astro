---
interface Props {
  title?: string;
  description?: string;
}

import '../styles/global.css';

const { title = 'HaikaiTech | Software Engineer & Freelance Web Developer Malaysia', description = 'Freelance software engineer in Malaysia. I build custom web apps, dashboards, and interactive systems with React, .NET, and Unity. Book a free call.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href="https://haikaitech.my/" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content="https://haikaitech.my/" />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://haikaitech.my/og-image.png" />
  <meta name="twitter:card" content="summary" />
  <!-- JSON-LD Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Iffat Haikal",
    "url": "https://haikaitech.my/",
    "jobTitle": "Software Engineer",
    "description": "Freelance software engineer building web apps, dashboards, and interactive systems.",
    "sameAs": [
      "https://github.com/name-iffat",
      "https://www.linkedin.com/in/iffathaikal/"
    ]
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "HaikaiTech",
    "url": "https://haikaitech.my/",
    "description": "Freelance software engineering portfolio — React, .NET, Unity, and custom web development."
  }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Patrick+Hand&family=VT323&display=swap"
    rel="stylesheet">
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-82BQD8BX9G"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-82BQD8BX9G', { send_page_view: true });
  </script>
</head>
<body>
  <slot />
  <div class="paper-texture"></div>
</body>
</html>
